import sqlite3

conn = sqlite3.connect("database.db")
c = conn.cursor()

c.execute("""
CREATE TABLE posts (
    id INTEGER PRIMARY KEY,
    song TEXT,
    artist TEXT,
    clip TEXT,
    mood TEXT
)
""")

c.execute("""
CREATE TABLE groups (
    id INTEGER PRIMARY KEY,
    name TEXT,
    genre TEXT
)
""")

conn.commit()
conn.close()
